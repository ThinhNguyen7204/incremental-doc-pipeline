# Provider selection: gemini or openai
AI_PROVIDER=gemini

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
VECTOR_STORE_ID=
ASSISTANT_ID=
OPENAI_ASSISTANT_MODEL=gpt-4o-mini

# Daily job configuration
ARTICLE_LIMIT=100
ARTICLES_DIR=data/articles
ARTICLE_MANIFEST_PATH=data/article_manifest.json
GEMINI_FILES_PATH=data/gemini_files.json
DAILY_JOB_LOG_PATH=logs/daily_job_last_run.json

# Optional: Zendesk API (not required for public Help Center articles)
ZENDESK_EMAIL=
ZENDESK_TOKEN=
ZENDESK_SUBDOMAIN=optisigns
